getter HTMLFormElement::method()
%{
	dom_string *val = NULL;
	dom_html_form_element_get_method(FORM_NODE, &val);
	if (val == NULL) { duk_push_lstring(ctx, "get", 3); return 1; }
	duk_push_lstring(ctx, dom_string_data(val), dom_string_length(val));
	dom_string_unref(val);
	return 1;
%}

setter HTMLFormElement::method()
%{
	dom_string *str = NULL;
	duk_size_t slen;
