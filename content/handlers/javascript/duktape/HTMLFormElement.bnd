		dom_html_form_element_set_method(FORM_NODE, str);
		dom_string_unref(str);
	}
	return 0;
%}

getter HTMLFormElement::name()
%{
	dom_string *val = NULL;
	dom_element_get_attribute(((node_private_t *)priv)->node,
		corestring_dom_name, &val);
	if (val == NULL) { duk_push_lstring(ctx, "", 0); return 1; }
	duk_push_lstring(ctx, dom_string_data(val), dom_string_length(val));
	dom_string_unref(val);
	return 1;
%}

setter HTMLFormElement::name()
%{
	dom_string *str = NULL;
	duk_size_t slen;
	const char *s = duk_safe_to_lstring(ctx, 0, &slen);
	if (dom_string_create((const uint8_t *)s, slen, &str) == DOM_NO_ERR) {
		dom_element_set_attribute(((node_private_t *)priv)->node,
			corestring_dom_name, str);
		dom_string_unref(str);
	}
	return 0;
%}

getter HTMLFormElement::target()
%{
	dom_string *val = NULL;
	dom_html_form_element_get_target(FORM_NODE, &val);
	if (val == NULL) { duk_push_lstring(ctx, "", 0); return 1; }
	duk_push_lstring(ctx, dom_string_data(val), dom_string_length(val));
