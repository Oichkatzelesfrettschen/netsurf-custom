method Document::close()
%{
	/* No-op: parser already completed */
	return 0;
%}

method Document::open()
%{
	/* No-op: no live document.open support */
	duk_push_this(ctx);
	return 1;
%}

getter Document::anchors()
%{
	/* Legacy: returns <a> elements with a name attribute */
	dom_nodelist *nodes = NULL;
	dom_exception exc;

	exc = dom_document_get_elements_by_tag_name(
		((node_private_t *)priv)->node,
		corestring_dom_a, &nodes);
	if (exc != DOM_NO_ERR || nodes == NULL) {
		duk_push_array(ctx);
		return 1;
	}

	uint32_t nlen = 0;
	dom_nodelist_get_length(nodes, &nlen);

	duk_push_array(ctx);
	uint32_t idx = 0;
	for (uint32_t i = 0; i < nlen; i++) {
		dom_node *item = NULL;
		exc = dom_nodelist_item(nodes, i, &item);
		if (exc != DOM_NO_ERR || item == NULL) continue;

		bool has_name = false;
		dom_element_has_attribute((dom_element *)item,
					  corestring_dom_name, &has_name);
		if (has_name) {
			if (dukky_push_node(ctx, item)) {
				duk_put_prop_index(ctx, -2, idx++);
			}
		}
		dom_node_unref(item);
	}
	dom_nodelist_unref(nodes);
	return 1;
%}

getter Document::designMode()
%{
	duk_push_this(ctx);
	duk_get_prop_string(ctx, -1, MAGIC(designMode));
	if (duk_is_undefined(ctx, -1)) {
		duk_pop_2(ctx);
		duk_push_lstring(ctx, "off", 3);
	} else {
		duk_remove(ctx, -2);
	}
	return 1;
%}

setter Document::designMode()
%{
	const char *s = duk_safe_to_string(ctx, 0);
	duk_push_this(ctx);
	if (strcasecmp(s, "on") == 0) {
		duk_push_lstring(ctx, "on", 2);
	} else {
		duk_push_lstring(ctx, "off", 3);
	}
	duk_put_prop_string(ctx, -2, MAGIC(designMode));
	return 0;
%}

getter Document::currentScript()
%{
	duk_push_null(ctx);
	return 1;
%}

getter Document::activeElement()
%{
	/* Return <body> or null (simplified -- no focus tracking) */
	struct dom_nodelist *nodes = NULL;
	struct dom_node *retnode = NULL;
	dom_exception exc;

	exc = dom_document_get_elements_by_tag_name(priv->parent.node,
						    corestring_dom_BODY,
						    &nodes);
	if (exc != DOM_NO_ERR || nodes == NULL) {
		duk_push_null(ctx);
		return 1;
	}

	exc = dom_nodelist_item(nodes, 0, &retnode);
	dom_nodelist_unref(nodes);
	if (exc != DOM_NO_ERR || retnode == NULL) {
		duk_push_null(ctx);
		return 1;
	}

	dukky_push_node(ctx, retnode);
	dom_node_unref(retnode);
	return 1;
%}

method Document::prepend()
%{
	dom_node *doc_node = ((node_private_t *)priv)->node;
	dom_node *first = NULL;
	dom_exception exc;
	duk_idx_t argc = duk_get_top(ctx);

	exc = dom_node_get_first_child(doc_node, &first);
	if (exc != DOM_NO_ERR) return 0;

	for (duk_idx_t i = 0; i < argc; i++) {
		if (duk_is_object(ctx, i)) {
			duk_get_prop_string(ctx, i, dukky_magic_string_private);
			node_private_t *np = duk_get_pointer(ctx, -1);
			duk_pop(ctx);
			if (np == NULL || np->node == NULL) continue;
			dom_node *ref = NULL;
			if (first != NULL) {
				exc = dom_node_insert_before(doc_node,
					np->node, first, &ref);
			} else {
				exc = dom_node_append_child(doc_node,
					np->node, &ref);
			}
			if (exc == DOM_NO_ERR && ref != NULL)
				dom_node_unref(ref);
		}
	}
	if (first != NULL) dom_node_unref(first);
	return 0;
%}

method Document::append()
%{
	dom_node *doc_node = ((node_private_t *)priv)->node;
	dom_exception exc;
	duk_idx_t argc = duk_get_top(ctx);

	for (duk_idx_t i = 0; i < argc; i++) {
		if (duk_is_object(ctx, i)) {
			duk_get_prop_string(ctx, i, dukky_magic_string_private);
			node_private_t *np = duk_get_pointer(ctx, -1);
			duk_pop(ctx);
			if (np == NULL || np->node == NULL) continue;
			dom_node *ref = NULL;
			exc = dom_node_append_child(doc_node, np->node, &ref);
			if (exc == DOM_NO_ERR && ref != NULL)
				dom_node_unref(ref);
		}
	}
	return 0;
%}

method Document::replaceChildren()
%{
	dom_node *doc_node = ((node_private_t *)priv)->node;
	dom_exception exc;
	duk_idx_t argc = duk_get_top(ctx);

	/* Remove all existing children */
	dom_node *child = NULL;
	exc = dom_node_get_first_child(doc_node, &child);
	while (exc == DOM_NO_ERR && child != NULL) {
		dom_node *cref = NULL;
		exc = dom_node_remove_child(doc_node, child, &cref);
		if (exc == DOM_NO_ERR && cref != NULL) dom_node_unref(cref);
		dom_node_unref(child);
		child = NULL;
		exc = dom_node_get_first_child(doc_node, &child);
	}

	/* Append new children */
	for (duk_idx_t i = 0; i < argc; i++) {
		if (duk_is_object(ctx, i)) {
			duk_get_prop_string(ctx, i, dukky_magic_string_private);
			node_private_t *np = duk_get_pointer(ctx, -1);
			duk_pop(ctx);
			if (np == NULL || np->node == NULL) continue;
			dom_node *ref = NULL;
			exc = dom_node_append_child(doc_node, np->node, &ref);
			if (exc == DOM_NO_ERR && ref != NULL)
				dom_node_unref(ref);
		}
	}
	return 0;
%}

