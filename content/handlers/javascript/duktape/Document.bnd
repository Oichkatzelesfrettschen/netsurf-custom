method Document::getElementsByName()
%{
	dom_nodelist *nodes = NULL;
	dom_exception exc;
	duk_size_t len;
	const char *str = duk_safe_to_lstring(ctx, 0, &len);
	dom_string *name_str;

	exc = dom_string_create((const uint8_t *)str, len, &name_str);
	if (exc != DOM_NO_ERR) return 0;

	exc = dom_html_document_get_elements_by_name(
		(dom_html_document *)((node_private_t *)priv)->node,
		name_str, &nodes);
	dom_string_unref(name_str);
	if (exc != DOM_NO_ERR || nodes == NULL) return 0;

	dukky_push_generics(ctx, "makeListProxy");

	duk_push_pointer(ctx, nodes);
	dukky_create_object(ctx, PROTO_NAME(NODELIST), 1);
	dom_nodelist_unref(nodes);

	if (dukky_pcall(ctx, 1, false) != 0) {
		return 0;
	}
	return 1;
%}

