	return 0;
%}

getter HTMLButtonElement::willValidate()
%{
	duk_push_boolean(ctx, false);
	return 1;
%}

getter HTMLButtonElement::validationMessage()
%{
	duk_push_lstring(ctx, "", 0);
	return 1;
%}

method HTMLButtonElement::checkValidity()
%{
	duk_push_boolean(ctx, true);
	return 1;
%}
