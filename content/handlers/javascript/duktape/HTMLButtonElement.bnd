prologue HTMLButtonElement()
%{
#include <dom/html/html_button_element.h>
#include <dom/html/html_element.h>
#include "utils/corestrings.h"

#define BUTTON_NODE ((dom_html_button_element *)((node_private_t *)priv)->node)
%}

init HTMLButtonElement(struct dom_html_element *html_button_element::html_element);

getter HTMLButtonElement::disabled()
%{
	bool val = false;
	dom_html_button_element_get_disabled(BUTTON_NODE, &val);
	duk_push_boolean(ctx, val);
	return 1;
%}

setter HTMLButtonElement::disabled()
%{
	dom_html_button_element_set_disabled(BUTTON_NODE, duk_to_boolean(ctx, 0));
	return 0;
%}

getter HTMLButtonElement::name()
%{
	dom_string *val = NULL;
	dom_html_button_element_get_name(BUTTON_NODE, &val);
	if (val == NULL) { duk_push_lstring(ctx, "", 0); return 1; }
	duk_push_lstring(ctx, dom_string_data(val), dom_string_length(val));
	dom_string_unref(val);
	return 1;
%}

setter HTMLButtonElement::name()
%{
	dom_string *str = NULL;
	duk_size_t slen;
	const char *s = duk_safe_to_lstring(ctx, 0, &slen);
	if (dom_string_create((const uint8_t *)s, slen, &str) == DOM_NO_ERR) {
		dom_html_button_element_set_name(BUTTON_NODE, str);
		dom_string_unref(str);
	}
	return 0;
%}

getter HTMLButtonElement::value()
%{
	dom_string *val = NULL;
	dom_html_button_element_get_value(BUTTON_NODE, &val);
	if (val == NULL) { duk_push_lstring(ctx, "", 0); return 1; }
	duk_push_lstring(ctx, dom_string_data(val), dom_string_length(val));
	dom_string_unref(val);
	return 1;
%}

setter HTMLButtonElement::value()
%{
	dom_string *str = NULL;
	duk_size_t slen;
	const char *s = duk_safe_to_lstring(ctx, 0, &slen);
	if (dom_string_create((const uint8_t *)s, slen, &str) == DOM_NO_ERR) {
		dom_html_button_element_set_value(BUTTON_NODE, str);
		dom_string_unref(str);
	}
	return 0;
%}

getter HTMLButtonElement::form()
%{
	dom_html_form_element *form = NULL;
	dom_exception exc;

	exc = dom_html_button_element_get_form(BUTTON_NODE, &form);
	if (exc == DOM_NO_ERR && form != NULL) {
		dukky_push_node(ctx, (dom_node *)form);
		dom_node_unref(form);
		return 1;
	}
	/* Fallback: walk DOM tree for nearest <form> ancestor */
	dom_node *cur = ((node_private_t *)priv)->node;
	dom_node_ref(cur);
	while (cur != NULL) {
		dom_node *parent = NULL;
		exc = dom_node_get_parent_node(cur, &parent);
		dom_node_unref(cur);
		if (exc != DOM_NO_ERR || parent == NULL) break;
		cur = parent;
		dom_html_element_type tag_type;
		tag_type = DOM_HTML_ELEMENT_TYPE__UNKNOWN;
		exc = dom_html_element_get_tag_type(cur, &tag_type);
		if (exc == DOM_NO_ERR &&
		    tag_type == DOM_HTML_ELEMENT_TYPE_FORM) {
			dukky_push_node(ctx, cur);
			dom_node_unref(cur);
			return 1;
		}
	}
	duk_push_null(ctx);
	return 1;
%}

getter HTMLButtonElement::type()
%{
	dom_string *val = NULL;
	dom_html_button_element_get_type(BUTTON_NODE, &val);
	if (val == NULL) { duk_push_lstring(ctx, "submit", 6); return 1; }
	duk_push_lstring(ctx, dom_string_data(val), dom_string_length(val));
	dom_string_unref(val);
	return 1;
%}

setter HTMLButtonElement::type()
%{
	dom_string *str = NULL;
	duk_size_t slen;
	const char *s = duk_safe_to_lstring(ctx, 0, &slen);
	if (dom_string_create((const uint8_t *)s, slen, &str) == DOM_NO_ERR) {
		dom_element_set_attribute(
			(dom_element *)((node_private_t *)priv)->node,
			corestring_dom_type, str);
		dom_string_unref(str);
	}
	return 0;
%}

getter HTMLButtonElement::formAction()
%{
	dom_string *val = NULL;
