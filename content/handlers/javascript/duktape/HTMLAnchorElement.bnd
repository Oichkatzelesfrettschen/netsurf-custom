prologue HTMLAnchorElement()
%{
#include <dom/html/html_anchor_element.h>

#define ANCHOR_NODE ((dom_html_anchor_element *)((node_private_t *)priv)->node)
%}

init HTMLAnchorElement(struct dom_html_element *html_anchor_element::html_element);

/* -- String properties (get/set dom_string) -- */

getter HTMLAnchorElement::href()
%{
	dom_string *val = NULL;
	dom_html_anchor_element_get_href(ANCHOR_NODE, &val);
	if (val == NULL) { duk_push_lstring(ctx, "", 0); return 1; }
	duk_push_lstring(ctx, dom_string_data(val), dom_string_length(val));
	dom_string_unref(val);
	return 1;
%}

setter HTMLAnchorElement::href()
%{
	dom_string *str = NULL;
	duk_size_t slen;
	const char *s = duk_safe_to_lstring(ctx, 0, &slen);
	if (dom_string_create((const uint8_t *)s, slen, &str) == DOM_NO_ERR) {
		dom_html_anchor_element_set_href(ANCHOR_NODE, str);
		dom_string_unref(str);
	}
	return 0;
%}

