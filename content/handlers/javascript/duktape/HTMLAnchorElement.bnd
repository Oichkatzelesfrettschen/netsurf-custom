getter HTMLAnchorElement::text()
%{
	/* WHY: anchor.text is an alias for textContent per HTML spec */
	dom_string *val = NULL;
	dom_node_get_text_content(((node_private_t *)priv)->node, &val);
	if (val == NULL) { duk_push_lstring(ctx, "", 0); return 1; }
	duk_push_lstring(ctx, dom_string_data(val), dom_string_length(val));
	dom_string_unref(val);
	return 1;
%}

setter HTMLAnchorElement::text()
%{
	dom_string *str = NULL;
	duk_size_t slen;
	const char *s = duk_safe_to_lstring(ctx, 0, &slen);
	if (dom_string_create((const uint8_t *)s, slen, &str) == DOM_NO_ERR) {
		dom_node_set_text_content(((node_private_t *)priv)->node, str);
		dom_string_unref(str);
	}
	return 0;
%}

getter HTMLAnchorElement::coords();
setter HTMLAnchorElement::coords();

getter HTMLAnchorElement::rev();
setter HTMLAnchorElement::rev();

getter HTMLAnchorElement::shape();
setter HTMLAnchorElement::shape();
