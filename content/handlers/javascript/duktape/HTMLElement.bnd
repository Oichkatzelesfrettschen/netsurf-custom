prologue HTMLElement()
%{
#include <utils/corestrings.h>
#include <dom/html/html_element.h>

#define HANDLER_MAGIC MAGIC(HANDLER_MAP)
#define HTML_ELEMENT_NODE ((dom_html_element *)((node_private_t *)priv)->node)
%}

init HTMLElement(struct dom_html_element *html_element::element);

/* -- dir / lang / title: string properties via dom_html_element API -- */

getter HTMLElement::dir()
%{
	dom_string *val = NULL;
	dom_html_element_get_dir(HTML_ELEMENT_NODE, &val);
	if (val == NULL) { duk_push_lstring(ctx, "", 0); return 1; }
	duk_push_lstring(ctx, dom_string_data(val), dom_string_length(val));
	dom_string_unref(val);
	return 1;
%}

setter HTMLElement::dir()
%{
	dom_string *str = NULL;
	duk_size_t slen;
	const char *s = duk_safe_to_lstring(ctx, 0, &slen);
	if (dom_string_create((const uint8_t *)s, slen, &str) == DOM_NO_ERR) {
		dom_html_element_set_dir(HTML_ELEMENT_NODE, str);
		dom_string_unref(str);
	}
	return 0;
%}

getter HTMLElement::lang()
%{
	dom_string *val = NULL;
	dom_html_element_get_lang(HTML_ELEMENT_NODE, &val);
	if (val == NULL) { duk_push_lstring(ctx, "", 0); return 1; }
	duk_push_lstring(ctx, dom_string_data(val), dom_string_length(val));
	dom_string_unref(val);
	return 1;
%}

setter HTMLElement::lang()
%{
	dom_string *str = NULL;
	duk_size_t slen;
	const char *s = duk_safe_to_lstring(ctx, 0, &slen);
