/* -- Integer properties -- */

getter HTMLInputElement::maxLength()
%{
	int32_t val = -1;
	dom_html_input_element_get_max_length(INPUT_NODE, &val);
	duk_push_int(ctx, val);
	return 1;
%}

setter HTMLInputElement::maxLength()
%{
	dom_html_input_element_set_max_length(INPUT_NODE, (uint32_t)duk_to_int(ctx, 0));
	return 0;
%}

getter HTMLInputElement::size()
%{
	dom_ulong val = 20;
	dom_html_input_element_get_size(INPUT_NODE, &val);
	duk_push_uint(ctx, (duk_uint_t)val);
	return 1;
%}

setter HTMLInputElement::size()
%{
	dom_html_input_element_set_size(INPUT_NODE, (dom_ulong)duk_to_uint(ctx, 0));
	return 0;
%}

/* -- Read-only string -- */

getter HTMLInputElement::type()
%{
	dom_string *val = NULL;
	dom_html_input_element_get_type(INPUT_NODE, &val);
	if (val == NULL) { duk_push_lstring(ctx, "text", 4); return 1; }
	duk_push_lstring(ctx, dom_string_data(val), dom_string_length(val));
	dom_string_unref(val);
	return 1;
%}

/* -- Deferred: valueAsNumber, valueHigh, valueLow (non-standard or complex) -- */
getter HTMLInputElement::valueAsNumber();
setter HTMLInputElement::valueAsNumber();

getter HTMLInputElement::valueHigh();
setter HTMLInputElement::valueHigh();

getter HTMLInputElement::valueLow();
setter HTMLInputElement::valueLow();
