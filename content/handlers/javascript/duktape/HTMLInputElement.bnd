/* -- Boolean properties -- */

getter HTMLInputElement::checked()
%{
	bool val = false;
	dom_html_input_element_get_checked(INPUT_NODE, &val);
	duk_push_boolean(ctx, val);
	return 1;
%}

setter HTMLInputElement::checked()
%{
	dom_html_input_element_set_checked(INPUT_NODE, duk_to_boolean(ctx, 0));
	return 0;
%}

getter HTMLInputElement::defaultChecked()
%{
	bool val = false;
	dom_html_input_element_get_default_checked(INPUT_NODE, &val);
	duk_push_boolean(ctx, val);
	return 1;
%}

setter HTMLInputElement::defaultChecked()
%{
	dom_html_input_element_set_default_checked(INPUT_NODE, duk_to_boolean(ctx, 0));
	return 0;
