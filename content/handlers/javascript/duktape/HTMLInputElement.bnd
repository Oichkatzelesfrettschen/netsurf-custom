getter HTMLInputElement::indeterminate()
%{
	duk_push_this(ctx);
	duk_get_prop_string(ctx, -1, MAGIC(indeterminate));
	if (duk_is_undefined(ctx, -1)) {
		duk_pop_2(ctx);
		duk_push_boolean(ctx, false);
	} else {
		duk_remove(ctx, -2);
	}
	return 1;
%}

setter HTMLInputElement::indeterminate()
%{
	duk_push_this(ctx);
	duk_push_boolean(ctx, duk_to_boolean(ctx, 0));
	duk_put_prop_string(ctx, -2, MAGIC(indeterminate));
	return 0;
%}

