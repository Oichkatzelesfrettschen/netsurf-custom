%}

getter HTMLTextAreaElement::wrap()
%{
	dom_string *val = NULL;
	dom_element_get_attribute(
		(dom_element *)((node_private_t *)priv)->node,
		corestring_dom_wrap, &val);
	if (val == NULL) { duk_push_lstring(ctx, "soft", 4); return 1; }
	duk_push_lstring(ctx, dom_string_data(val), dom_string_length(val));
