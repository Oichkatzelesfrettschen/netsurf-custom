%}

getter HTMLTextAreaElement::textLength()
%{
	dom_string *val = NULL;
	dom_html_text_area_element_get_value(TEXTAREA_NODE, &val);
	if (val == NULL) { duk_push_uint(ctx, 0); return 1; }
	duk_push_uint(ctx, (duk_uint_t)dom_string_length(val));
	dom_string_unref(val);
