getter HTMLTextAreaElement::labels()
%{
	duk_push_array(ctx);
	return 1;
%}

getter HTMLTextAreaElement::required()
%{
	bool has = false;
	dom_element_has_attribute(
		(dom_element *)((node_private_t *)priv)->node,
		corestring_dom_required, &has);
	duk_push_boolean(ctx, has);
	return 1;
%}

