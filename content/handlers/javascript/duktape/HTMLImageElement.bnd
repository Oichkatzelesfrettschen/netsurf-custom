/* -- Boolean property -- */

getter HTMLImageElement::isMap()
%{
	bool val = false;
	dom_html_image_element_get_is_map(IMAGE_NODE, &val);
	duk_push_boolean(ctx, val);
	return 1;
%}

setter HTMLImageElement::isMap()
%{
	dom_html_image_element_set_is_map(IMAGE_NODE, duk_to_boolean(ctx, 0));
	return 0;
%}
