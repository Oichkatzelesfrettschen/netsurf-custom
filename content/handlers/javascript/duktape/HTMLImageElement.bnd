/* -- Integer properties (dom_ulong) -- */

getter HTMLImageElement::height()
%{
	dom_ulong val = 0;
	dom_html_image_element_get_height(IMAGE_NODE, &val);
	duk_push_uint(ctx, (duk_uint_t)val);
	return 1;
%}

setter HTMLImageElement::height()
%{
	dom_html_image_element_set_height(IMAGE_NODE, (dom_ulong)duk_to_uint(ctx, 0));
	return 0;
%}

