<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<title>NetSurf JS Binding Gap Report</title>
<style>
  body { font-family: monospace; background: #1e1e1e; color: #d4d4d4; margin: 0; padding: 16px; }
  h1 { color: #9cdcfe; font-size: 1.4em; }
  .summary { display: flex; gap: 16px; margin-bottom: 16px; flex-wrap: wrap; }
  .stat { background: #2d2d2d; border-radius: 4px; padding: 10px 18px; min-width: 100px; text-align: center; }
  .stat .label { font-size: 0.8em; color: #808080; }
  .stat .count { font-size: 1.8em; font-weight: bold; }
  .absent { color: #ff6b6b; }
  .stub { color: #ffd93d; }
  .partial { color: #6bcfff; }
  .done { color: #6bcb77; }
  table { border-collapse: collapse; width: 100%; font-size: 0.85em; }
  th { background: #2d2d2d; color: #9cdcfe; padding: 6px 10px; text-align: left; cursor: pointer; user-select: none; }
  th.sorted-asc::after { content: " \25B2"; }
  th.sorted-desc::after { content: " \25BC"; }
  td { padding: 4px 10px; border-bottom: 1px solid #2d2d2d; }
  tr:hover td { background: #2d2d2d; }
  .score { font-weight: bold; }
  a { color: #9cdcfe; text-decoration: none; }
  a:hover { text-decoration: underline; }
  .meta { font-size: 0.75em; color: #606060; margin-bottom: 8px; }
  input#filter { background: #2d2d2d; color: #d4d4d4; border: 1px solid #444; padding: 4px 8px;
                 font-family: monospace; margin-bottom: 8px; width: 300px; }
</style>
</head>
<body>
<h1>NetSurf JS Binding Gap Report</h1>
<div class="meta">Generated: {{ generated }} | Commit: {{ commit }}</div>

<div class="summary">
  {% for status, color in [("absent","absent"),("stub","stub"),("partial","partial"),("done","done")] %}
  <div class="stat">
    <div class="label">{{ status }}</div>
    <div class="count {{ color }}">{{ counts[status] }}</div>
  </div>
  {% endfor %}
  <div class="stat">
    <div class="label">total</div>
    <div class="count">{{ total }}</div>
  </div>
</div>

<input id="filter" type="text" placeholder="Filter by class or member..." oninput="filterTable()">

<table id="gaptable">
<thead>
<tr>
  <th onclick="sortTable(0)">ID</th>
  <th onclick="sortTable(1)">Class</th>
  <th onclick="sortTable(2)">Member</th>
  <th onclick="sortTable(3)">Kind</th>
  <th onclick="sortTable(4)">Status</th>
  <th onclick="sortTable(5)">Score</th>
  <th onclick="sortTable(6)">Impact</th>
  <th onclick="sortTable(7)">Effort</th>
  <th onclick="sortTable(8)">WPT</th>
  <th onclick="sortTable(9)">Last Touched</th>
</tr>
</thead>
<tbody>
{% for e in gaps %}
<tr>
  <td><a href="GAP-{{ e.id[4:] }}.html">{{ e.id }}</a></td>
  <td>{{ e.class_name }}</td>
  <td>{{ e.member }}</td>
  <td>{{ e.kind }}</td>
  <td class="{{ e.status }}">{{ e.status }}</td>
  <td class="score">{{ "%.2f"|format(e.score) }}</td>
  <td>{{ e.impact }}</td>
  <td>{{ e.effort }}</td>
  <td>{{ e.wpt_tests }}</td>
  <td>{{ e.last_touched }}</td>
</tr>
{% endfor %}
</tbody>
</table>

<script>
var sortDir = {};
function sortTable(col) {
  var table = document.getElementById("gaptable");
  var tbody = table.tBodies[0];
  var rows = Array.from(tbody.rows);
  var asc = !sortDir[col];
  sortDir = {};
  sortDir[col] = asc;
  rows.sort(function(a, b) {
    var av = a.cells[col].textContent.trim();
    var bv = b.cells[col].textContent.trim();
    var an = parseFloat(av), bn = parseFloat(bv);
    if (!isNaN(an) && !isNaN(bn)) return asc ? an - bn : bn - an;
    return asc ? av.localeCompare(bv) : bv.localeCompare(av);
  });
  rows.forEach(function(r) { tbody.appendChild(r); });
  var ths = table.tHead.rows[0].cells;
  for (var i = 0; i < ths.length; i++) {
    ths[i].className = "";
  }
  ths[col].className = asc ? "sorted-asc" : "sorted-desc";
}
function filterTable() {
  var q = document.getElementById("filter").value.toLowerCase();
  var rows = document.getElementById("gaptable").tBodies[0].rows;
  for (var i = 0; i < rows.length; i++) {
    var text = rows[i].textContent.toLowerCase();
    rows[i].style.display = text.indexOf(q) >= 0 ? "" : "none";
  }
}
</script>
</body>
</html>
