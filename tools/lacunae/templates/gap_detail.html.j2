<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="utf-8">
<title>{{ entry.id }} -- {{ entry.class_name }}::{{ entry.member }}</title>
<style>
  body { font-family: monospace; background: #1e1e1e; color: #d4d4d4; margin: 0; padding: 16px; }
  h1 { color: #9cdcfe; font-size: 1.2em; }
  .back { color: #9cdcfe; text-decoration: none; font-size: 0.9em; }
  .field { margin: 6px 0; }
  .label { color: #808080; display: inline-block; width: 130px; }
  .absent { color: #ff6b6b; }
  .stub { color: #ffd93d; }
  .partial { color: #6bcfff; }
  .done { color: #6bcb77; }
  pre { background: #2d2d2d; padding: 12px; border-radius: 4px; overflow-x: auto; font-size: 0.85em; }
</style>
</head>
<body>
<a class="back" href="index.html">&larr; Back to index</a>
<h1>{{ entry.id }}: {{ entry.class_name }}::{{ entry.member }}</h1>
<div class="field"><span class="label">Status</span> <span class="{{ entry.status }}">{{ entry.status }}</span></div>
<div class="field"><span class="label">Kind</span> {{ entry.kind }}</div>
<div class="field"><span class="label">Score</span> {{ "%.3f"|format(entry.score) }}</div>
<div class="field"><span class="label">Impact</span> {{ entry.impact }}/10</div>
<div class="field"><span class="label">Effort</span> {{ entry.effort }}/10</div>
<div class="field"><span class="label">WPT tests</span> {{ entry.wpt_tests }}</div>
<div class="field"><span class="label">cppcheck hits</span> {{ entry.cppcheck_hits }}</div>
<div class="field"><span class="label">Last touched</span> {{ entry.last_touched }}</div>
<div class="field"><span class="label">Churn (90d)</span> {{ entry.churn }}</div>
<div class="field"><span class="label">.bnd file</span> {{ entry.bnd_file or "(absent)" }}</div>
<div class="field"><span class="label">Notes</span> {{ entry.notes }}</div>

<h2>Resolution outline</h2>
<pre>{{ resolution }}</pre>
</body>
</html>
